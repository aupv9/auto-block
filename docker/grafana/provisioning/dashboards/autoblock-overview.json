{
  "title": "AutoBlock Overview",
  "uid": "autoblock-overview",
  "schemaVersion": 38,
  "refresh": "10s",
  "time": { "from": "now-1h", "to": "now" },
  "panels": [
    {
      "id": 1,
      "title": "Blacklist Rate (IPs/min)",
      "type": "stat",
      "gridPos": { "x": 0, "y": 0, "w": 4, "h": 4 },
      "targets": [{
        "expr": "rate(autoblock_blacklist_total[1m]) * 60",
        "legendFormat": "IPs/min"
      }],
      "options": { "colorMode": "background", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "fieldConfig": { "defaults": { "thresholds": {
        "steps": [
          { "color": "green", "value": null },
          { "color": "yellow", "value": 5 },
          { "color": "red", "value": 20 }
        ]
      }}}
    },
    {
      "id": 2,
      "title": "WAF Actions (total)",
      "type": "stat",
      "gridPos": { "x": 4, "y": 0, "w": 4, "h": 4 },
      "targets": [{
        "expr": "sum(autoblock_waf_actions_total)",
        "legendFormat": "Total actions"
      }],
      "options": { "colorMode": "value", "reduceOptions": { "calcs": ["lastNotNull"] } }
    },
    {
      "id": 3,
      "title": "WAF Push Errors",
      "type": "stat",
      "gridPos": { "x": 8, "y": 0, "w": 4, "h": 4 },
      "targets": [{
        "expr": "sum(autoblock_waf_action_errors_total)",
        "legendFormat": "Errors"
      }],
      "options": { "colorMode": "background", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "fieldConfig": { "defaults": { "thresholds": {
        "steps": [
          { "color": "green", "value": null },
          { "color": "red", "value": 1 }
        ]
      }}}
    },
    {
      "id": 4,
      "title": "WAF Push Latency p95 (seconds)",
      "type": "stat",
      "gridPos": { "x": 12, "y": 0, "w": 4, "h": 4 },
      "targets": [{
        "expr": "histogram_quantile(0.95, rate(autoblock_waf_action_latency_seconds_bucket[5m]))",
        "legendFormat": "p95"
      }],
      "options": { "colorMode": "background", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "fieldConfig": { "defaults": {
        "unit": "s",
        "thresholds": {
          "steps": [
            { "color": "green", "value": null },
            { "color": "yellow", "value": 10 },
            { "color": "red", "value": 30 }
          ]
        }
      }}
    },
    {
      "id": 5,
      "title": "Blacklisted IPs Over Time",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 4, "w": 12, "h": 8 },
      "targets": [{
        "expr": "rate(autoblock_blacklist_total[5m]) * 60",
        "legendFormat": "{{tenant}} {{source}}"
      }],
      "fieldConfig": { "defaults": { "unit": "short", "color": { "mode": "palette-classic" } } }
    },
    {
      "id": 6,
      "title": "WAF Action Latency Histogram",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 4, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, rate(autoblock_waf_action_latency_seconds_bucket[5m]))",
          "legendFormat": "p50"
        },
        {
          "expr": "histogram_quantile(0.95, rate(autoblock_waf_action_latency_seconds_bucket[5m]))",
          "legendFormat": "p95"
        },
        {
          "expr": "histogram_quantile(0.99, rate(autoblock_waf_action_latency_seconds_bucket[5m]))",
          "legendFormat": "p99"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "s" } }
    },
    {
      "id": 7,
      "title": "Events Processed by State",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 12, "w": 12, "h": 8 },
      "targets": [{
        "expr": "rate(autoblock_events_processed_total[5m])",
        "legendFormat": "{{state}}"
      }],
      "fieldConfig": { "defaults": { "unit": "short" } }
    },
    {
      "id": 8,
      "title": "API Requests",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 12, "w": 12, "h": 8 },
      "targets": [{
        "expr": "rate(autoblock_api_requests_total[5m])",
        "legendFormat": "{{method}} {{path}} {{status}}"
      }],
      "fieldConfig": { "defaults": { "unit": "reqps" } }
    }
  ]
}
