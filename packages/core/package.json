{
  "name": "@autoblock/core",
  "version": "0.1.0",
  "description": "Core rate limiting algorithms and penalty FSM for AutoBlock",
  "type": "module",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.cjs",
      "types": "./dist/index.d.ts"
    }
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@opentelemetry/api": "^1.9.0",
    "ioredis": "^5.0.0",
    "neverthrow": "^6.1.0"
  },
  "devDependencies": {
    "@types/node": "^20.12.7",
    "testcontainers": "^10.8.1",
    "tsup": "^8.0.2",
    "typescript": "^5.4.5",
    "vitest": "^1.5.2"
  },
  "peerDependencies": {
    "ioredis": "^5.0.0"
  }
}
